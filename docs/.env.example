# Azure Trusted Signing credentials
# Copy this file to .env and fill in the values.
# Do not commit .env -- it must be gitignored.

# Entra ID tenant ID
# Azure portal > Entra ID > Overview > Tenant ID
AZURE_TENANT_ID=

# Application (client) ID of the app registration
# Azure portal > Entra ID > App registrations > your app > Application (client) ID
AZURE_CLIENT_ID=

# Client secret value (not the secret ID)
# Azure portal > Entra ID > App registrations > your app > Certificates & secrets
AZURE_CLIENT_SECRET=
